{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --dotenv .env.local",
    "dev:https": "sudo -E env \"PATH=$PATH\" nuxt dev --dotenv .env.local-auth-certificates --https --sslKey ./local.devnet.nosana.io+2-key.pem --sslCert ./local.devnet.nosana.io+2.pem --port 443 --host 127.0.0.1",
    "generate": "nuxt generate --dotenv .env.${APP_ENV:=production}",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "exit 0; eslint . --ext .vue,.js,.ts,.jsx,.cjs,.mjs --ignore-path .gitignore",
    "lint:fix": "eslint . --ext .vue,.js,.ts,.jsx,.cjs,.mjs --fix --ignore-path .gitignore"
  },
  "devDependencies": {
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@types/event-source-polyfill": "^1.0.5",
    "@vite-pwa/nuxt": "^1.0.7",
    "@vueuse/nuxt": "^14.0.0",
    "bulma": "1.0.4",
    "nuxt": "^4.2.1",
    "prettier": "^3.4.2",
    "sass": "^1.94.1",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vite-svg-loader": "^5.1.0",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "dependencies": {
    "@chenfengyuan/vue-countdown": "^2.1.2",
    "@fortawesome/vue-fontawesome": "^3.0.8",
    "@nosana/sdk": "^0.4.69",
    "@solana/wallet-adapter-wallets": "^0.19.25",
    "@vueuse/components": "^14.0.0",
    "@vueuse/integrations": "^14.0.0",
    "bn.js": "^5.2.1",
    "event-source-polyfill": "^1.0.31",
    "nuxt-gtag": "^4.0.0",
    "solana-wallets-vue": "^0.6.0",
    "vue-countup-v3": "^1.4.1",
    "vue-toastification": "^2.0.0-rc.5"
  }
}
